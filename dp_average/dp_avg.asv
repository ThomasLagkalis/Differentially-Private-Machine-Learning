%% NoisyAverage Clamping-Down (Alg. 2.3)
avg = zeros(length(epsilon), num_of_exp);
true_avg = zeros(length(epsilon), num_of_exp);
for i=1:length(epsilon)
    for j=1:num_of_exp
        [true_avg(i,j), avg(i,j)] = noisy_avg_clampingDown(epsilon(i), a_min, a_max, D);
    end
end
error = abs(avg- true_avg);

window = 1000;

for i = 1:length(epsilon)
    % Compute moving average across experiments (row-wise)
    mov_avg_err = movmean(error(i,:), window);
    
    % Plot
    plot(mov_avg_err,  'LineWidth', 1.5, 'DisplayName', sprintf('\\epsilon = %.0e', epsilon(i)));
end

